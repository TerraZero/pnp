model Building {
  id Int @id @default(autoincrement()) /// { label: 'Building ID' }
  name String /// { key: 'label' }
  game String /// { label: 'Game', disabled: true }
  floors Floor[]
}

model Floor {
  id Int @id @default(autoincrement())
  building Building[]
  tiles Tile[]
  name String /// { key: 'label' }
  floor Int
}

model Tile {
  id Int @id @default(autoincrement())
  floor Floor[]
  value String /// [JSON]
}