/// { meta: { temp: true, label: 'Music' } }
/// { routes: { base: "/temp/admin/tmusic" } }
/// { routes: { edit: "/temp/admin/tmusic/:id/edit" } }
/// { routes: { add: "/temp/admin/tmusic/add" } }
model Tmusic {
  id Int @id @default(autoincrement()) /// { label: 'Music ID' }
  status Int @default(1)
  label String /// { key: 'label' }
  src String
  type String /// { fallback: "youtube" }
  start Int @default(0)
  end Int @default(0)
  volume Float @default(0.5)
  playlists Tplaylist[]
  value String @default("{}") /// [JSON] { label: 'Configuration' }
}

